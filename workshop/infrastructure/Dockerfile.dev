FROM python:3.12-slim

WORKDIR /workspace

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install dependencies from lock file for reproducible builds.
# The project source is mounted at runtime, so we only need pyproject + lock here.
COPY pyproject.toml .python-version uv.lock README.md ./
RUN uv sync --frozen

COPY infrastructure/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Entrypoint auto-generates protobuf stubs then delegates to uv run <cmd>.
ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
