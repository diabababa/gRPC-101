FROM python:3.12-slim

WORKDIR /workspace

COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Install all deps including dev (pytest, pytest-bdd, locust, ruff, poe)
COPY pyproject.toml .python-version ./
RUN uv sync --frozen || uv sync

# Default: generate protos then drop into shell
# Override CMD in docker-compose for specific tasks
ENTRYPOINT ["uv", "run"]
CMD ["bash"]
