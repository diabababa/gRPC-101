{
  "title": "gRPC Chat Service",
  "uid": "grpc-chat",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(grpc_requests_total)",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate (RPS)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(grpc_requests_total[30s]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(grpc_requests_total{status=\"error\"}[30s])) / sum(rate(grpc_requests_total[30s]))",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.01},
              {"color": "red", "value": 0.05}
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Request Rate by Method",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (method) (rate(grpc_requests_total[30s]))",
          "legendFormat": "{{method}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latency p50 / p95 / p99",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, method) (rate(grpc_request_duration_seconds_bucket[30s])))",
          "legendFormat": "p50 {{method}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(grpc_request_duration_seconds_bucket[30s])))",
          "legendFormat": "p95 {{method}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, method) (rate(grpc_request_duration_seconds_bucket[30s])))",
          "legendFormat": "p99 {{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s"}
      }
    }
  ],
  "time": {"from": "now-5m", "to": "now"}
}
